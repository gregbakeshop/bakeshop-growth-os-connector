# Bakeshop Growth OS Connector — environment
# Copy to .env (dev) or set on the VPS (prod). Never commit real secrets.

# From the Shopify Partner Dashboard app (populated by `npm run config:link`)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Public URL of this app (Caddy → localhost:3001 in prod)
SHOPIFY_APP_URL=https://connector.bakeshop.digital

# Read-only scopes. Defaults baked into shopify.server.ts if unset.
SCOPES=read_orders,read_products,read_customers,read_discounts

# 32 random bytes, base64-encoded — encrypts access tokens at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# Prisma SQLite location (default points at prisma/dev.sqlite)
DATABASE_URL="file:./dev.sqlite"

# Optional: override the daily sync cron (default "0 4 * * *" UTC)
# SYNC_CRON=0 4 * * *
